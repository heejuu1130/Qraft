  "spacing": {
    "scale": ["4px", "6px", "8px", "12px", "16px", "20px", "24px", "28px", "32px", "48px", "64px", "78px", "80px"],
    "base": "8px"
  },
  "radius": {
    "none": "0px",
    "sharp": "4px",
    "subtle": "6px",
    "card": "8px",
    "alert": "16px"
  },
  "elevation": {
    "default": "none",
    "level0": "flat",
    "level1": "1px hairline border",
    "level2": "surface contrast",
    "level3": "section alternation"
  },
  "motion": {
    "shaderSpeed": "0.02-0.08",
    "uiTransition": "500-900ms",
    "pageTransition": "700-1000ms",
    "feedbackState": "0-2000ms"
  }
}
