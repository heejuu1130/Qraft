{
  "meta": {
    "name": "Qraft Design System",
    "purpose": "Future service UI foundation. No components are defined here.",
    "sources": {
      "typography": "MiniMax-inspired type scale adapted to Qraft",
      "layoutAndUi": "Runway-inspired spacing, containment, radius, elevation, and motion adapted to Qraft",
      "color": "Qraft-owned desert palette"
    }
  },
  "color": {
    "qraft": {
      "background": "#120b07",
      "backgroundRaised": "#2a170e",
      "ink": "#f5dfbd",
      "inkMuted": "#d2ad7c",
      "line": "#d9ad73",
      "ember": "#8d4f31",
      "clay": "#b87345",
      "sand": "#efd3a2"
    },
    "ui": {
      "black": "#000000",
      "deep": "#030303",
      "surface": "#1a1a1a",
      "border": "#27272a",
      "silver": "#c9ccd1",
      "muted": "#a7a7a7",
      "light": "#fefefe",
      "cloud": "#e9ecf2"
    }
  },
  "font": {
    "display": "Outfit",
    "ui": "DM Sans",
    "mono": "DM Mono"
  },
  "typography": {
    "display.hero": {
      "font": "Outfit",
      "size": "80px",
      "weight": 500,
      "lineHeight": 1.1,
      "letterSpacing": "0"
    },
    "heading.section": {
      "font": "Outfit",
      "size": "31px",
      "weight": 600,
      "lineHeight": 1.5,
      "letterSpacing": "0"
    },
    "heading.compact": {
      "font": "DM Sans",
      "size": "32px",
      "weight": 600,
      "lineHeight": 0.88,
      "letterSpacing": "0"
    },
    "title.card": {
      "font": "Outfit",
      "size": "28px",
      "weight": 600,
      "lineHeight": 1.71,
      "letterSpacing": "0"
    },
    "heading.sub": {
      "font": "DM Sans",
      "size": "24px",
      "weight": 500,
      "lineHeight": 1.5,
      "letterSpacing": "0"
    },
    "label.feature": {
      "font": "DM Sans",
      "size": "18px",
      "weight": 500,
      "lineHeight": 1.5,
      "letterSpacing": "0"
    },
    "body.large": {
      "font": "DM Sans",
      "size": "20px",
      "weight": 500,
      "lineHeight": 1.5,
      "letterSpacing": "0"
    },
    "body.default": {
      "font": "DM Sans",
      "size": "16px",
      "weight": 400,
      "lineHeight": 1.5,
      "letterSpacing": "-0.16px"
    },
    "body.strong": {
      "font": "DM Sans",
      "size": "16px",
      "weight": 700,
      "lineHeight": 1.5,
      "letterSpacing": "0"
    },
    "nav.link": {
      "font": "DM Sans",
      "size": "14px",
      "weight": 500,
      "lineHeight": 1.5,
      "letterSpacing": "0"
    },
    "button.small": {
      "font": "DM Sans",
      "size": "13px",
      "weight": 600,
      "lineHeight": 1.5,
      "letterSpacing": "0"
    },
    "caption": {
      "font": "DM Sans",
      "size": "13px",
      "weight": 400,
      "lineHeight": 1.7,
      "letterSpacing": "0"
    },
    "label.small": {
      "font": "DM Sans",
      "size": "12px",
      "weight": 600,
      "lineHeight": 1.5,
      "letterSpacing": "0.12em"
    },
    "micro": {
      "font": "DM Mono",
      "size": "10px",
      "weight": 500,
      "lineHeight": 1.8,
      "letterSpacing": "0.18em"
    }
